@import "tailwindcss";
@plugin "@tailwindcss/typography";

/* 将 Tailwind v4 暗色模式从 media query 切换为 class 策略（配合 next-themes） */
@variant dark (&:where(.dark, .dark *));

:root {
  --background: #ffffff;
  --foreground: #171717;
}

.dark {
  --background: #0a0a0a;
  --foreground: #ededed;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
}

/* KaTeX 公式块防止宽屏溢出，允许横向滚动 */
.katex-display {
  overflow-x: auto;
  overflow-y: hidden;
  padding-block: 0.25rem;
}

/* 行内公式字号与正文保持一致 */
.katex {
  font-size: 1em;
}

/* KaTeX 暗色模式：公式颜色跟随正文前景色 */
.dark .katex,
.dark .katex-html {
  color: inherit;
}

/* KaTeX 分数线、根号线等边框在暗色下用 currentColor */
.dark .katex .frac-line,
.dark .katex .sqrt > .root,
.dark .katex .overline > .overline-line,
.dark .katex .underline > .underline-line {
  border-color: currentColor;
}

/* prose 内标题增加中文行高 */
.prose h1,
.prose h2,
.prose h3 {
  line-height: 1.6;
}

/* ── 打印讲义样式 ─────────────────────────────────────────────── */

/* 屏幕上隐藏打印容器 */
.print-portal {
  display: none;
}

@media print {
  /* 打印时隐藏所有 body 直接子元素，只显示打印容器 */
  body > *:not(.print-portal) {
    display: none !important;
  }

  /* A4 纸张设置 */
  @page {
    size: A4;
    margin: 20mm;
  }

  /* 打印容器基础排版 */
  .print-portal {
    display: block !important;
    font-family: 'Times New Roman', Georgia, 'Noto Serif SC', 'SimSun', serif;
    font-size: 11pt;
    line-height: 1.8;
    color: #000;
    background: #fff;
  }

  /* 讲义标题区 */
  .print-header {
    text-align: center;
    padding-bottom: 8mm;
    margin-bottom: 10mm;
    border-bottom: 2pt solid #000;
  }

  .print-header h1 {
    font-size: 22pt;
    font-weight: bold;
    margin: 0 0 2mm;
    color: #000;
  }

  .print-header p {
    font-size: 9.5pt;
    color: #555;
    margin: 0;
  }

  /* 题目块 — 避免跨页截断 */
  .print-question {
    break-inside: avoid;
    page-break-inside: avoid;
    padding-bottom: 6mm;
    margin-bottom: 8mm;
    border-bottom: 0.5pt solid #ccc;
  }

  .print-question:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  /* 元信息行（题号、知识点、年份、来源、难度） */
  .print-question-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4mm;
    align-items: baseline;
    font-size: 9pt;
    color: #666;
    margin-bottom: 3mm;
  }

  .print-question-number {
    font-size: 11pt;
    font-weight: bold;
    color: #000;
  }

  /* 题目正文 */
  .print-question-content {
    font-size: 11pt;
    line-height: 1.9;
  }

  /* 作答空白区 */
  .print-answer-space {
    min-height: 45mm;
